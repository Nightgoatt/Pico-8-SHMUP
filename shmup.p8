pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	cls()
	ship=1
	shipx=64
	shipy=64
	spdx=0
	spdy=0
	
	shipspr=0
	flamespr=5
	bullspr=16
	
	bullx=64
	bully=-10
	
	muzzle=0
	
	score=30000
	lives=3
	bombs=3
	
	starx={}
	stary={}
	starspd={}
	
	for i=1,100 do
		add(starx,flr(rnd(128)))
		add(stary,flr(rnd(128)))
		add(starspd,rnd(1.5)+0.5)
	end
	
end

function _update()
	spdx=0
	spdy=0
	shipspr=1
	
	--controls
	if btn(0) then
		spdx=-2
		shipspr=2
	elseif btn(1) then
		spdx=2
		shipspr=3
	elseif btn(2) then
		spdy=-2
	elseif btn(3) then
		spdy=2
	end
	
	--shoot
	if btnp(5) then
		bullx=shipx
		bully=shipy-3
		sfx(0)
		muzzle=5
	end

	--moving the ship
	shipx+=spdx
	shipy+=spdy
	
		--moving the bullet
	bully-=2
	
	--animate flame
	flamespr+=1
	if flamespr>9 then
		flamespr=5
	end
	
	--animate muzzle flash
	if muzzle>0 then 
		muzzle-=1
	end
	
	--animate bullet
	bullspr+=1
	if bullspr>22 then
		bullspr=16
	end
	
	--off the screen collision
	if shipx>120 then 
		shipx=120
	elseif shipx<1 then
		shipx=1
	elseif shipy>120 then
		shipy=120
	elseif shipy<1 then
		shipy=1
	end

end

function _draw()
	cls()
	starfield()
	animatestars()
	spr(shipspr,shipx,shipy)
	spr(bullspr,bullx,bully)
	spr(flamespr,shipx,shipy+7)
	
	if muzzle>0 then
		circfill(shipx+3,shipy-2,muzzle,7)
	end
	
	print("score: "..score,40,1,12)
	
	--lives ui
	lives=3
	for i=1,3 do
		if lives>=i then
			spr(11,i*9,1)
		else
			spr(12,i*9,1)
		end
	end
	
	--bombs ui
	bombs=3
	for i=1,3 do
		if bombs>=i then
			spr(24,90+i*9,1)
		else
			spr(25,90+i*9,1)
		end
	end
	
end


-->8
function starfield()
	for i=1,#starx do
		local scol=6
		
		if starspd[i]<1 then
			scol=1
		elseif starspd[i]<1.5 then
			scol=13
		end
	
		pset(starx[i],stary[i],scol)
	end
end

function animatestars()
	for i=1,#stary do
		local sy=stary[i]
		sy+=starspd[i]
		
		if sy>128 then
			sy-=128
		end
		stary[i]=sy
	end
end
